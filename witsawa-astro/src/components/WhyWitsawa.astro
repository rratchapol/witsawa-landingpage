<style is:global>
  /* WHY WITSAWA */
  #why {
    background-image: var(--bg-url);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    position: relative;
    overflow: hidden;
  }
  #why::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(3, 1, 12, 0.74);
    pointer-events: none;
  }
  /* 2-column: icon card left · content right */
  .why-two-col {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 4.5rem;
    align-items: start;
  }

  /* ── Icon card (left column) ── */
  .why-icon-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .why-icon-card {
    position: relative;
    width: 400px;
    height: 400px;
    border-radius: 28px;
    background: linear-gradient(
      135deg,
      rgba(168, 85, 247, 0.22),
      rgba(79, 70, 229, 0.14)
    );
    border: 1px solid rgba(168, 85, 247, 0.35);
    box-shadow:
      0 0 60px rgba(168, 85, 247, 0.22),
      0 0 120px rgba(124, 58, 237, 0.1),
      inset 0 0 60px rgba(168, 85, 247, 0.06);
    backdrop-filter: blur(20px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    animation: why-card-float 6s ease-in-out infinite;
  }
  @keyframes why-card-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  /* Inner radial highlight */
  .why-icon-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 35% 30%,
      rgba(168, 85, 247, 0.2) 0%,
      transparent 60%
    );
    pointer-events: none;
  }
  /* Corner accent lines */
  .why-icon-card::after {
    content: "";
    position: absolute;
    top: 18px;
    left: 18px;
    right: 18px;
    bottom: 18px;
    border-radius: 20px;
    border: 1px solid rgba(168, 85, 247, 0.12);
    pointer-events: none;
  }
  /* Outer ambient glow blob */
  .why-icon-glow {
    position: absolute;
    inset: -50px;
    background: radial-gradient(
      ellipse,
      rgba(124, 58, 237, 0.28) 0%,
      transparent 68%
    );
    filter: blur(40px);
    pointer-events: none;
    z-index: -1;
    animation: why-glow-pulse 6s ease-in-out infinite;
  }
  @keyframes why-glow-pulse {
    0%,
    100% {
      opacity: 0.7;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.06);
    }
  }

  /* ── Content column (right) — left-aligned ── */
  .why-heading {
    font-size: clamp(1.8rem, 2.6vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 0.9rem;
    text-align: left;
  }
  .why-sub {
    font-size: 0.98rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 520px;
    text-align: left;
  }
  .why-hdr {
    text-align: left;
    margin-bottom: 2.5rem;
  }
  .why-hdr .solutions-badge {
    margin-bottom: 1.5rem;
  }
  .why-hdr .why-heading {
    margin-left: 0;
  }
  .why-hdr .why-sub {
    margin-left: 0;
  }
  .why-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.85rem;
    margin-bottom: 0;
    width: 100%;
  }
  /* Gradient specifically for "You Can Trust" */
  .why-trust-grad {
    background: linear-gradient(90deg, #a855f7, #6366f1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .why-stat-block {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 14px;
    padding: 1.1rem 0.75rem;
    backdrop-filter: blur(12px);
    text-align: center;
    transition:
      border-color 0.3s,
      transform 0.3s;
  }
  .why-stat-block:hover {
    border-color: rgba(168, 85, 247, 0.5);
    transform: translateY(-4px);
  }
  .why-stat-num {
    font-size: 1.85rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: #ffffff;
    -webkit-text-fill-color: #ffffff;
    line-height: 1;
    margin-bottom: 0.3rem;
  }
  .why-stat-label {
    font-size: 0.7rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }
  .why-features {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .why-feature {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 1rem 1.2rem;
    backdrop-filter: blur(12px);
    transition:
      border-color 0.3s,
      background 0.3s;
  }
  .why-feature:hover {
    border-color: rgba(168, 85, 247, 0.3);
    background: rgba(168, 85, 247, 0.05);
  }
  .why-feature-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .why-feature-text h4 {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: var(--text-primary);
  }
  .why-feature-text p {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  @media (max-width: 1200px) {
    .why-two-col {
      grid-template-columns: 440px 1fr;
      gap: 3rem;
    }
    .why-icon-card {
      width: 340px;
      height: 340px;
    }
  }
  @media (max-width: 1024px) {
    .why-two-col {
      grid-template-columns: 340px 1fr;
      gap: 2.5rem;
      align-items: start;
    }
    .why-icon-col {
      gap: 1rem;
    }
    .why-icon-card {
      width: 280px;
      height: 280px;
      animation: none;
    }
    .why-icon-glow {
      display: block;
    }
    .why-stats-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 600px;
      margin: 0 auto;
    }
    .why-heading {
      text-align: left;
    }
    .why-sub {
      text-align: left;
    }
    .why-hdr {
      text-align: left;
    }
  }
  @media (max-width: 768px) {
    .why-two-col {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .why-icon-col {
      order: 2;
      align-items: center;
      gap: 0.75rem;
    }
    .why-icon-card {
      width: min(280px, 80vw);
      height: min(280px, 80vw);
      animation: none;
      display: flex;
    }
    .why-icon-glow {
      display: block;
    }
    .why-heading {
      text-align: center;
    }
    .why-sub {
      text-align: center;
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }
    .why-hdr {
      text-align: center;
    }
    .why-stats-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 100%;
      margin: 0 auto;
    }
  }
</style>

<script>
  function setupCounters() {
    const stats = document.querySelectorAll(".why-stat-num");
    if (!stats.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const targetElement = entry.target as HTMLElement;
            const targetValue = parseInt(
              targetElement.getAttribute("data-target") || "0",
              10,
            );
            const suffix = targetElement.getAttribute("data-suffix") || "";

            let startTime: number | null = null;
            const duration = 2000; // 2 seconds

            function updateCounter(currentTime: number) {
              if (!startTime) startTime = currentTime;
              const progress = currentTime - startTime;

              if (progress < duration) {
                // easeOutQuart function
                const easeProgress = 1 - Math.pow(1 - progress / duration, 4);
                const currentValue = Math.floor(targetValue * easeProgress);
                targetElement.innerText = currentValue + suffix;
                requestAnimationFrame(updateCounter);
              } else {
                targetElement.innerText = targetValue + suffix;
              }
            }

            requestAnimationFrame(updateCounter);
            observer.unobserve(targetElement); // Animate only once
          }
        });
      },
      { threshold: 0.1 },
    );

    stats.forEach((stat) => observer.observe(stat));
  }

  // Astro module scripts are deferred by default, execution here is safe.
  setupCounters();
</script>
