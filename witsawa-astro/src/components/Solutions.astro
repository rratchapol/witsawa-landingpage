    display: block;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .sol-vis-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, transparent, rgba(10, 2, 28, 0.98));
