---

---

<section id="solutions" class="solutions-section">
  <div class="reveal" style="text-align:center;margin-bottom:0">
    <div class="solutions-badge">
      <span class="dot"></span>
      Solutions
    </div>
  </div>
  <div class="reveal reveal-delay-1" style="text-align:center">
    <h2 class="section-title" style="text-align:center">
      Platforms Built for <span class="grad">Every Industry</span>
    </h2>
  </div>
  <div
    class="reveal reveal-delay-2"
    style="text-align:center;max-width:600px;margin-left:auto;margin-right:auto"
  >
    <p class="section-sub" style="margin:0 auto">
      Purpose-built digital solutions designed to solve complex operational
      challenges across industries and business models.
    </p>
  </div>

  <div class="solutions-grid">
    <!-- Card 1: Enterprise — large top-left -->
    <div class="solution-card sol-card-1 reveal">
      <div class="sol-vis">
        <div class="sol-vis-bg"></div>
        <svg
          viewBox="0 0 380 240"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <image
            href="/images/EnterpriseDigitalPlatforms.png"
            x="0"
            y="0"
            width="380"
            height="240"
            preserveAspectRatio="xMidYMid meet"
          />
        </svg>
        <div class="sol-vis-fade"></div>
      </div>
      <div class="sol-body">
        <div class="sol-label">Enterprise</div>
        <h3>Enterprise Digital Platforms</h3>
        <p>
          Comprehensive business operation systems with real-time analytics,
          multi-tenant architecture, and deep integrations across your entire
          tech stack.
        </p>
        <div class="sol-pills">
          <span class="sol-pill">ERP</span>
          <span class="sol-pill">Analytics</span>
          <span class="sol-pill">Multi-tenant</span>
          <span class="sol-pill">APIs</span>
        </div>
      </div>
    </div>

    <!-- Card 2: AI Automation — medium top-right -->
    <div class="solution-card sol-card-2 reveal reveal-delay-1">
      <div class="sol-vis">
        <div class="sol-vis-bg"></div>
        <svg
          viewBox="0 0 380 240"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <image
            href="/images/AIAutomationSystems.png"
            x="0"
            y="0"
            width="380"
            height="240"
            preserveAspectRatio="xMidYMid meet"
          />
        </svg>
        <div class="sol-vis-fade"></div>
      </div>
      <div class="sol-body">
        <div class="sol-label">AI &amp; Automation</div>
        <h3>AI Automation Systems</h3>
        <p>
          Intelligent workflow automation powered by LLMs, AI agents, and custom
          machine learning pipelines built for real-world scale.
        </p>
        <div class="sol-pills">
          <span class="sol-pill">LLM Agents</span>
          <span class="sol-pill">RAG</span>
          <span class="sol-pill">ML Pipelines</span>
        </div>
      </div>
    </div>

    <!-- Card 3: Startup Development — medium bottom-left -->
    <div class="solution-card sol-card-3 reveal reveal-delay-1">
      <div class="sol-vis">
        <div class="sol-vis-bg"></div>
        <svg
          viewBox="0 0 380 240"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <image
            href="/images/StartupProductDevelopment.png"
            x="0"
            y="0"
            width="380"
            height="240"
            preserveAspectRatio="xMidYMid meet"
          />
        </svg>
        <div class="sol-vis-fade"></div>
      </div>
      <div class="sol-body">
        <div class="sol-label">Startup</div>
        <h3>Startup Product Development</h3>
        <p>
          From MVP to scale — rapid product development with lean architecture,
          fast iteration cycles, and investor-ready engineering.
        </p>
        <div class="sol-pills">
          <span class="sol-pill">MVP</span>
          <span class="sol-pill">Full-Stack</span>
          <span class="sol-pill">Fast Delivery</span>
        </div>
      </div>
    </div>

    <!-- Card 4: Customer Engagement — large bottom-right -->
    <div class="solution-card sol-card-4 reveal reveal-delay-2">
      <div class="sol-vis">
        <div class="sol-vis-bg"></div>
        <svg
          viewBox="0 0 380 240"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <image
            href="/images/CustomerEngagementPlatforms.png"
            x="0"
            y="0"
            width="380"
            height="240"
            preserveAspectRatio="xMidYMid meet"
          />
        </svg>
        <div class="sol-vis-fade"></div>
      </div>
      <div class="sol-body">
        <div class="sol-label">Customer Experience</div>
        <h3>Customer Engagement Platforms</h3>
        <p>
          Omnichannel engagement systems that unify messaging, CRM, analytics,
          and automation to deliver personalised customer experiences at scale.
        </p>
        <div class="sol-pills">
          <span class="sol-pill">Omnichannel</span>
          <span class="sol-pill">CRM</span>
          <span class="sol-pill">Automation</span>
          <span class="sol-pill">Analytics</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* SOLUTIONS */
  /* ── SOLUTIONS: background ── */
  #solutions {
    position: relative;
    overflow: hidden;
    background-image: url("/images/solutions-bg.jpg");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .solutions-section {
    background-image: url("/images/solutions-bg.jpg");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  /* Dark overlay for readability */
  #solutions::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(4, 2, 14, 0.38);
    pointer-events: none;
    z-index: 0;
  }
  #solutions::after {
    content: none;
  }
  #solutions > * {
    position: relative;
    z-index: 1;
  }

  /* ── SOLUTIONS: asymmetric 2x2 grid ── */
  .solutions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.25rem;
    margin-top: 80px;
  }
  /* Top-left: large */
  .sol-card-1 {
    grid-column: 1;
    grid-row: 1;
  }
  /* Top-right: medium */
  .sol-card-2 {
    grid-column: 2;
    grid-row: 1;
  }
  /* Bottom-left: medium */
  .sol-card-3 {
    grid-column: 1;
    grid-row: 2;
  }
  /* Bottom-right: large */
  .sol-card-4 {
    grid-column: 2;
    grid-row: 2;
  }

  /* ── SOLUTIONS: card base ── */
  .solution-card {
    position: relative;
    border-radius: 20px;
    overflow: visible; /* allow neon border ::after to extend 1px outside */
    isolation: isolate;
    display: flex;
    flex-direction: column;
    background:
      /* soft radial centre glow */
      radial-gradient(
        ellipse 90% 60% at 50% 20%,
        rgba(110, 35, 200, 0.12) 0%,
        rgba(70, 14, 155, 0.07) 40%,
        transparent 65%
      ),
      /* smooth multi-stop diagonal gradient */
      linear-gradient(
          160deg,
          rgba(68, 16, 132, 0.26) 0%,
          rgba(50, 10, 108, 0.22) 14%,
          rgba(30, 6, 76, 0.4) 30%,
          rgba(16, 3, 48, 0.56) 50%,
          rgba(8, 1, 26, 0.72) 68%,
          rgba(5, 1, 16, 0.84) 84%,
          rgba(3, 0, 12, 0.92) 100%
        );
    border: 1px solid rgba(140, 70, 230, 0.22);
    backdrop-filter: blur(32px) saturate(1.4);
    -webkit-backdrop-filter: blur(32px) saturate(1.4);
    box-shadow:
      0 1px 0 0 rgba(180, 110, 255, 0.18) inset,
      0 20px 56px rgba(0, 0, 0, 0.55),
      0 0 40px rgba(88, 20, 200, 0.08);
    transition:
      transform 0.4s cubic-bezier(0.23, 1, 0.32, 1),
      border-color 0.35s ease,
      box-shadow 0.35s ease;
    cursor: default;
  }
  .solution-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      /* radial top-left soft glow */
      radial-gradient(
        ellipse 70% 50% at 20% 15%,
        rgba(148, 60, 230, 0.1) 0%,
        rgba(100, 28, 190, 0.05) 45%,
        transparent 70%
      ),
      /* diagonal corner accent */
      linear-gradient(
          135deg,
          rgba(155, 65, 240, 0.1) 0%,
          rgba(100, 24, 195, 0.04) 22%,
          transparent 52%,
          rgba(6, 1, 18, 0.06) 100%
        );
    pointer-events: none;
    z-index: 1;
    border-radius: inherit;
  }
  .solution-card:hover {
    transform: translateY(-11px);
    border-color: rgba(160, 90, 255, 0.38);
    box-shadow:
      0 1px 0 0 rgba(190, 130, 255, 0.28) inset,
      0 24px 64px rgba(0, 0, 0, 0.65),
      0 0 55px rgba(109, 28, 217, 0.18);
  }

  /* ── SOLUTIONS: neon border travel — same as What We Do cards ── */
  .solution-card::after {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: 21px;
    padding: 1px;
    background: conic-gradient(
      from var(--wwd-angle),
      transparent 0%,
      transparent 78%,
      rgba(109, 28, 217, 0.1) 83%,
      rgba(155, 80, 255, 0.55) 88%,
      rgba(200, 140, 255, 0.9) 92%,
      rgba(240, 180, 255, 1) 94%,
      rgba(200, 140, 255, 0.9) 96%,
      rgba(155, 80, 255, 0.5) 99%,
      transparent 100%
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 5;
  }
  .solution-card:hover::after {
    opacity: 1;
    animation: wwd-border-travel 4s linear infinite;
  }

  /* ── SOLUTIONS: illustration zone ── */
  .sol-vis {
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
    border-radius: 20px 20px 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 18px;
    box-sizing: border-box;
    height: 240px;
  }
  .sol-vis-bg {
    position: absolute;
    inset: 0;
    background:
      /* soft radial centre glow behind illustration */
      radial-gradient(
        ellipse 80% 65% at 50% 42%,
        rgba(130, 44, 225, 0.2) 0%,
        rgba(88, 18, 176, 0.12) 32%,
        rgba(44, 6, 104, 0.06) 58%,
        transparent 78%
      ),
      /* top-to-bottom tint — smooth multi-stop */
      linear-gradient(
          180deg,
          rgba(72, 16, 138, 0.28) 0%,
          rgba(48, 10, 106, 0.2) 18%,
          rgba(26, 4, 66, 0.14) 40%,
          rgba(12, 2, 34, 0.58) 66%,
          rgba(7, 1, 20, 0.84) 100%
        );
    pointer-events: none;
  }
  .sol-vis svg {
    width: 100%;
    height: auto;
    max-width: 340px;
    max-height: 192px;
    display: block;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    padding-top: 10px;
  }
  .sol-vis-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, transparent, rgba(10, 2, 28, 0.98));
    pointer-events: none;
    z-index: 2;
  }

  /* ── SOLUTIONS: card body ── */
  .sol-body {
    padding: 1.4rem 1.6rem 1.6rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 2;
  }
  .sol-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: rgba(168, 85, 247, 0.7);
    margin-bottom: 0.5rem;
  }
  .solution-card h3 {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.022em;
    line-height: 1.28;
    margin-bottom: 0.7rem;
    color: #f0e8ff;
  }
  .solution-card p {
    font-size: 0.84rem;
    color: rgba(200, 180, 240, 0.62);
    line-height: 1.68;
    margin-bottom: 0;
    flex: 1;
  }
  .sol-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(140, 70, 230, 0.12);
  }
  .sol-pill {
    font-size: 0.67rem;
    font-weight: 600;
    padding: 0.2rem 0.65rem;
    background: rgba(109, 28, 217, 0.14);
    border: 1px solid rgba(140, 70, 230, 0.26);
    border-radius: 100px;
    color: #c084fc;
    letter-spacing: 0.02em;
  }

  /* ── SOLUTIONS: badge pill (matches hero-badge style) ── */
  .solutions-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1.15rem;
    background: rgba(124, 58, 237, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.38);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--neon-purple);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    box-shadow:
      0 0 22px rgba(168, 85, 247, 0.18),
      inset 0 0 14px rgba(124, 58, 237, 0.08);
    cursor: default;
  }
  .solutions-badge .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--neon-purple);
    box-shadow: 0 0 7px rgba(168, 85, 247, 0.85);
    flex-shrink: 0;
  }

  /* Badge responsive */
  @media (max-width: 1024px) {
    .solutions-badge {
      padding: 0.35rem 1rem;
      font-size: 0.75rem;
    }
  }
  @media (max-width: 768px) {
    .solutions-badge {
      padding: 0.3rem 0.85rem;
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      max-width: 90vw;
      white-space: normal;
      text-align: center;
      justify-content: center;
    }
  }

  /* Responsive */
  @media (max-width: 900px) {
    .solutions-grid {
      grid-template-columns: 1fr;
    }
    .sol-card-1,
    .sol-card-2,
    .sol-card-3,
    .sol-card-4 {
      grid-column: 1;
      grid-row: auto;
    }
    .sol-vis {
      height: 220px;
      padding: 12px 16px;
    }
    .sol-vis svg {
      max-width: 300px;
      max-height: 176px;
    }
  }
  @media (max-width: 640px) {
    .sol-vis {
      height: 190px;
      padding: 10px 14px;
    }
    .sol-vis svg {
      max-width: 280px;
      max-height: 160px;
    }
  }

  /* legacy selectors kept for compat */
  .solution-img {
    display: none;
  }
  .solution-body {
    display: none;
  }
  .solution-tag {
    display: none;
  }
  .solution-features {
    display: none;
  }
  .feat-pill {
    display: none;
  }
</style>
