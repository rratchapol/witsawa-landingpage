---
import { getImage } from "astro:assets";
import ctaBg from "../assets/images/bg/ctaBg.webp";

const optimizedCtaBg = await getImage({ src: ctaBg });
---

<section id="cta" style={`--bg-url: url(${optimizedCtaBg.src})`}>
  <!-- Floating particles layer (overlay handled by #cta::before) -->
  <div class="hero-particles" id="ctaParticles"></div>
  <canvas id="cta-canvas"></canvas>
  <div class="cta-inner" style="position:relative;z-index:1;">
    <!-- Heading -->
    <div class="reveal">
      <h2 class="cta-v2-title">
        Ready to build the next generation of<br /><span class="grad"
          >your digital platform?</span
        >
      </h2>
    </div>

    <!-- Description -->
    <div class="reveal reveal-delay-1">
      <p class="cta-v2-desc">
        Partner with Witsawa to design and develop technology solutions that
        scale with your business.
      </p>
    </div>

    <!-- AI-bar style CTA -->
    <div class="reveal reveal-delay-2">
      <div class="cta-bar-wrap">
        <div class="cta-bar-inner">
          <!-- Left: prompt text with pulse dot -->
          <div class="cta-bar-left">
            <div class="cta-bar-dot"></div>
            <span class="cta-bar-prompt"
              >Tell us about your project — we&rsquo;ll take it from there.</span
            >
          </div>

          <!-- Right: CTA button -->
          <a href="/startProject" class="btn-cta-start">
            Start Your Project Today
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* CTA */
  #cta {
    text-align: center;
    position: relative;
    overflow: hidden;
    background-image: var(--bg-url);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    animation: ctaBgDrift 18s ease-in-out infinite alternate;
  }
  @keyframes ctaBgDrift {
    0% {
      background-position: center center;
    }
    50% {
      background-position: 55% 45%;
    }
    100% {
      background-position: center center;
    }
  }
  /* Dark overlay — sits above image, below all content */
  #cta::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(8, 10, 25, 0.72), rgba(8, 10, 25, 0.82));
    pointer-events: none;
    z-index: 0;
  }
  #cta-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }
  .btn-glow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #7c3aed, #2563eb);
    border: none;
    border-radius: 12px;
    color: #fff;
    font-family: "Inter", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow:
      0 0 40px rgba(124, 58, 237, 0.6),
      0 8px 30px rgba(0, 0, 0, 0.4);
    text-decoration: none;
    animation: glowPulse 3s ease-in-out infinite;
  }
  .btn-glow:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow:
      0 0 70px rgba(124, 58, 237, 0.8),
      0 12px 40px rgba(0, 0, 0, 0.5);
  }

  /* ── CTA v2: banner style ── */
  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 920px;
    margin: 0 auto;
  }
  .cta-v2-title {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.18;
    margin: 0 auto 1.2rem;
    max-width: 720px;
  }
  .cta-v2-desc {
    font-size: 1.02rem;
    color: var(--text-secondary);
    line-height: 1.72;
    max-width: 560px;
    margin: 0 auto 3rem;
  }
  /* Soft gradient banner card */
  .cta-bar-wrap {
    position: relative;
    border-radius: 24px;
    background: linear-gradient(
      135deg,
      rgba(88, 24, 130, 0.52) 0%,
      rgba(50, 14, 104, 0.6) 45%,
      rgba(24, 6, 72, 0.68) 100%
    );
    border: 1px solid rgba(168, 85, 247, 0.22);
    box-shadow:
      0 0 60px rgba(168, 85, 247, 0.28),
      0 0 120px rgba(99, 102, 241, 0.14),
      0 28px 72px rgba(0, 0, 0, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    animation: cta-banner-glow 5s ease-in-out infinite;
  }
  @keyframes cta-banner-glow {
    0%,
    100% {
      box-shadow:
        0 0 60px rgba(168, 85, 247, 0.28),
        0 0 120px rgba(99, 102, 241, 0.14),
        0 28px 72px rgba(0, 0, 0, 0.55),
        inset 0 1px 0 rgba(255, 255, 255, 0.06);
    }
    50% {
      box-shadow:
        0 0 90px rgba(168, 85, 247, 0.45),
        0 0 160px rgba(99, 102, 241, 0.22),
        0 28px 72px rgba(0, 0, 0, 0.55),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }
  }
  /* Banner inner layout */
  .cta-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3.5rem;
    background: transparent;
    border-radius: 24px;
    padding: 1.8rem 3.2rem;
  }
  .cta-bar-left {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 1;
    text-align: left;
  }
  /* Decorative accent bar — replaces cursor dot */
  .cta-bar-dot {
    display: none;
  }
  .cta-bar-prompt {
    font-size: 1.08rem;
    color: rgba(215, 195, 255, 0.82);
    font-weight: 500;
    font-style: normal;
    line-height: 1.6;
  }
  /* CTA button */
  .btn-cta-start {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 2.2rem;
    background: linear-gradient(135deg, #a855f7 0%, #6366f1 60%, #60a5fa 100%);
    border: none;
    border-radius: 999px;
    color: #fff;
    font-family: "Inter", sans-serif;
    font-size: 0.96rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-decoration: none;
    cursor: pointer;
    flex-shrink: 0;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
    box-shadow:
      0 0 36px rgba(168, 85, 247, 0.6),
      0 8px 24px rgba(0, 0, 0, 0.38);
    white-space: nowrap;
  }
  .btn-cta-start:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow:
      0 0 60px rgba(168, 85, 247, 0.85),
      0 12px 32px rgba(0, 0, 0, 0.48);
  }
  .btn-cta-start svg {
    transition: transform 0.25s ease;
  }
  .btn-cta-start:hover svg {
    transform: translateX(3px);
  }

  /* Responsive: CTA banner */
  @media (max-width: 768px) {
    .cta-bar-inner {
      flex-direction: column;
      align-items: center;
      padding: 1.5rem 2rem;
      gap: 2rem;
    }
    .cta-bar-left {
      align-items: center;
      text-align: center;
    }
    .btn-cta-start {
      width: 100%;
      justify-content: center;
    }
  }
  @media (max-width: 480px) {
    .cta-v2-title {
      font-size: 1.7rem;
    }
    .cta-bar-inner {
      padding: 1.2rem 1.4rem;
    }
    .cta-bar-prompt {
      font-size: 0.92rem;
    }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const canvas = document.getElementById("cta-canvas");
    const ctaSection = document.getElementById("cta");
    if (canvas && ctaSection) {
      const ctx = canvas.getContext("2d");
      let width, height;
      let particles = [];

      function resize() {
        width = canvas.width = ctaSection.offsetWidth;
        height = canvas.height = ctaSection.offsetHeight;
      }
      window.addEventListener("resize", resize);
      resize();

      class Particle {
        constructor() {
          this.x = Math.random() * width;
          this.y = Math.random() * height;
          this.vx = (Math.random() - 0.5) * 0.5;
          this.vy = (Math.random() - 0.5) * 0.5;
          this.radius = Math.random() * 1.5 + 0.5;
          this.alpha = Math.random() * 0.5 + 0.1;
        }
        update() {
          this.x += this.vx;
          this.y += this.vy;
          if (this.x < 0 || this.x > width) this.vx *= -1;
          if (this.y < 0 || this.y > height) this.vy *= -1;
        }
        draw() {
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(168, 85, 247, ${this.alpha})`;
          ctx.fill();
        }
      }

      for (let i = 0; i < 50; i++) particles.push(new Particle());

      function animate() {
        ctx.clearRect(0, 0, width, height);
        particles.forEach((p) => {
          p.update();
          p.draw();
        });

        particles.forEach((p1, i) => {
          for (let j = i + 1; j < particles.length; j++) {
            const p2 = particles[j];
            const dx = p1.x - p2.x;
            const dy = p1.y - p2.y;
            const dist = Math.sqrt(dx * dx + dy * dy);

            if (dist < 150) {
              ctx.beginPath();
              ctx.moveTo(p1.x, p1.y);
              ctx.lineTo(p2.x, p2.y);
              ctx.strokeStyle = `rgba(168, 85, 247, ${((150 - dist) / 150) * 0.15})`;
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          }
        });

        requestAnimationFrame(animate);
      }
      animate();
    }
  });
</script>
