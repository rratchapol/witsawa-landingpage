---
---
<section id="process">

  <div class="reveal"><span class="section-tag">How We Work</span></div>
  <div class="reveal reveal-delay-1">
    <h2 class="section-title" style="-webkit-text-fill-color:unset"><span style="color:#ffffff;-webkit-text-fill-color:#ffffff">Our Development </span><span class="grad">Process</span></h2>
  </div>
  <div class="reveal reveal-delay-2">
    <p class="section-sub">We follow a proven development process to deliver reliable and scalable digital solutions.</p>
  </div>

  <div class="process-timeline reveal">
    <div class="ptl-track">

      <!-- 01: Discovery -->
      <div class="pstep">
        <div class="pstep-icon-area">
          <div class="pstep-icon-box">
            <svg width="22" height="22" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="11" cy="11" r="7" stroke="#C084FC" stroke-width="1.5"/>
              <line x1="16.5" y1="16.5" x2="22" y2="22" stroke="#C084FC" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="8" y1="11" x2="14" y2="11" stroke="#C084FC" stroke-width="1.2" stroke-linecap="round"/>
              <line x1="11" y1="8" x2="11" y2="14" stroke="#C084FC" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </div>
        </div>
        <div class="pstep-num-wrap"><div class="pstep-num">01</div></div>
        <div class="pstep-body">
          <h4 class="pstep-title">Discovery</h4>
          <p class="pstep-desc">Define scope and requirements by understanding your business goals and challenges.</p>
        </div>
      </div>

      <!-- 02: System Architecture -->
      <div class="pstep">
        <div class="pstep-icon-area">
          <div class="pstep-icon-box">
            <svg width="22" height="22" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="3" width="8" height="8" rx="1.5" stroke="#60A5FA" stroke-width="1.4"/>
              <rect x="15" y="3" width="8" height="8" rx="1.5" stroke="#60A5FA" stroke-width="1.4"/>
              <rect x="9" y="15" width="8" height="8" rx="1.5" stroke="#60A5FA" stroke-width="1.4"/>
              <line x1="7" y1="11" x2="13" y2="15" stroke="#60A5FA" stroke-width="1.1" stroke-linecap="round"/>
              <line x1="19" y1="11" x2="13" y2="15" stroke="#60A5FA" stroke-width="1.1" stroke-linecap="round"/>
            </svg>
          </div>
        </div>
        <div class="pstep-num-wrap"><div class="pstep-num">02</div></div>
        <div class="pstep-body">
          <h4 class="pstep-title">System Architecture</h4>
          <p class="pstep-desc">Design a scalable, secure architecture built for performance and long-term maintainability.</p>
        </div>
      </div>

      <!-- 03: Development -->
      <div class="pstep">
        <div class="pstep-icon-area">
          <div class="pstep-icon-box">
            <svg width="22" height="22" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 8 L4 13 L9 18" stroke="#A78BFA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              <path d="M17 8 L22 13 L17 18" stroke="#A78BFA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              <line x1="14.5" y1="6" x2="11.5" y2="20" stroke="#A78BFA" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          </div>
        </div>
        <div class="pstep-num-wrap"><div class="pstep-num">03</div></div>
        <div class="pstep-body">
          <h4 class="pstep-title">Development</h4>
          <p class="pstep-desc">Build with modern practices and agile delivery cycles.</p>
        </div>
      </div>

      <!-- 04: Testing & QA -->
      <div class="pstep">
        <div class="pstep-icon-area">
          <div class="pstep-icon-box">
            <svg width="22" height="22" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M13 3 L22 7 V13 C22 18 17.5 22.5 13 24 C8.5 22.5 4 18 4 13 V7 Z"
                stroke="#4ADE80" stroke-width="1.4" stroke-linejoin="round" fill="none"/>
              <path d="M9 13 L11.5 15.5 L17 10" stroke="#4ADE80" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </div>
        </div>
        <div class="pstep-num-wrap"><div class="pstep-num">04</div></div>
        <div class="pstep-body">
          <h4 class="pstep-title">Testing &amp; QA</h4>
          <p class="pstep-desc">Rigorous testing for stability, security, and performance before go-live.</p>
        </div>
      </div>

      <!-- 05: Deployment -->
      <div class="pstep">
        <div class="pstep-icon-area">
          <div class="pstep-icon-box">
            <svg width="22" height="22" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M13 3 C13 3 20 8 20 14 C20 17 17.5 19.5 13 21 C8.5 19.5 6 17 6 14 C6 8 13 3 13 3Z"
                stroke="#38BDF8" stroke-width="1.4" fill="none"/>
              <line x1="13" y1="10" x2="13" y2="17" stroke="#38BDF8" stroke-width="1.3" stroke-linecap="round"/>
              <path d="M10 13 L13 10 L16 13" stroke="#38BDF8" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </div>
        </div>
        <div class="pstep-num-wrap"><div class="pstep-num">05</div></div>
        <div class="pstep-body">
          <h4 class="pstep-title">Deployment</h4>
          <p class="pstep-desc">Launch to secure cloud infrastructure, fully configured for production.</p>
        </div>
      </div>

      <!-- 06: Continuous Support -->
      <div class="pstep">
        <div class="pstep-icon-area">
          <div class="pstep-icon-box">
            <svg width="22" height="22" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 13 A8 8 0 1 1 13 21" stroke="#F472B6" stroke-width="1.4" stroke-linecap="round" fill="none"/>
              <path d="M13 21 L10 18 M13 21 L10 24" stroke="#F472B6" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              <circle cx="13" cy="13" r="3" stroke="#F472B6" stroke-width="1.3" fill="none"/>
            </svg>
          </div>
        </div>
        <div class="pstep-num-wrap"><div class="pstep-num">06</div></div>
        <div class="pstep-body">
          <h4 class="pstep-title">Continuous Support</h4>
          <p class="pstep-desc">Ongoing monitoring, maintenance, and updates to keep your system reliable.</p>
        </div>
      </div>

    </div><!-- /ptl-track -->
  </div><!-- /process-timeline -->
</section>
<style is:global>
  /* PROCESS */
  #process {
    background-image: url('/images/how-we-work-bg.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    position: relative;
    overflow: hidden;
  }
  /* dark overlay so text stays readable */
  #process::before {
    content: '';
    position: absolute; inset: 0;
    background: rgba(3,1,12,0.62);
    pointer-events: none; z-index: 0;
  }
  #process > * { position: relative; z-index: 1; }

  /* ── HOW WE WORK: horizontal timeline ── */

  /* pulse ring on step numbers */
  @keyframes ptl-pulse {
    0%,100% { opacity: 0.45; transform: scale(1); }
    50%      { opacity: 0.9;  transform: scale(1.08); }
  }

  .process-timeline { margin-top: 3rem; }

  /* The horizontal glowing line + 6 steps in a row */
  .ptl-track {
    display: flex;
    position: relative;
    align-items: flex-start;
  }

  /* Glowing line — sits at top of number circles (icon-area 80px + half circle 24px = 104px) */
  .ptl-track::before {
    content: '';
    position: absolute;
    top: 104px;
    left: calc(100% / 12);
    right: calc(100% / 12);
    height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(124,58,237,0.5)  8%,
      rgba(168,85,247,0.95) 30%,
      rgba(139,92,246,1)    50%,
      rgba(99,102,241,0.95) 70%,
      rgba(37,99,235,0.5)   92%,
      transparent 100%);
    box-shadow:
      0 0 10px rgba(168,85,247,0.55),
      0 0 22px rgba(168,85,247,0.28),
      0 0 40px rgba(124,58,237,0.15);
    z-index: 0;
  }

  /* Individual step */
  .pstep {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 1;
    padding: 0 0.4rem;
    cursor: default;
  }

  /* Icon box — fixed height area so all icons align */
  .pstep-icon-area {
    height: 80px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 8px;
  }
  .pstep-icon-box {
    width: 44px; height: 44px;
    border-radius: 10px;
    background: linear-gradient(135deg,
      rgba(124,58,237,0.28), rgba(37,99,235,0.16));
    border: 1px solid rgba(124,58,237,0.32);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 14px rgba(124,58,237,0.22);
    transition: box-shadow 0.3s, border-color 0.3s;
  }
  .pstep:hover .pstep-icon-box {
    box-shadow: 0 0 24px rgba(168,85,247,0.45);
    border-color: rgba(168,85,247,0.5);
  }

  /* Circular numbered indicator */
  .pstep-num-wrap {
    position: relative; z-index: 2;
    margin-bottom: 1rem;
  }
  .pstep-num {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #7c3aed, #2563eb);
    border: 2px solid rgba(255,255,255,0.18);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.78rem; font-weight: 800; color: #fff;
    letter-spacing: 0.02em;
    box-shadow:
      0 0 16px rgba(124,58,237,0.65),
      0 0 32px rgba(124,58,237,0.30),
      0 4px 14px rgba(0,0,0,0.4);
    position: relative;
    transition: box-shadow 0.3s;
  }
  /* pulsing outer ring */
  .pstep-num::after {
    content: '';
    position: absolute; inset: -6px;
    border-radius: 50%;
    border: 1px solid rgba(124,58,237,0.38);
    animation: ptl-pulse 2.4s ease-in-out infinite;
  }
  .pstep:hover .pstep-num {
    box-shadow:
      0 0 24px rgba(168,85,247,0.85),
      0 0 48px rgba(124,58,237,0.45),
      0 4px 16px rgba(0,0,0,0.5);
  }

  /* Title + description */
  .pstep-title {
    font-size: 0.9rem; font-weight: 700; margin-bottom: 0.45rem;
    color: var(--text-primary); letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .pstep-desc {
    font-size: 0.75rem; color: var(--text-secondary);
    line-height: 1.58; margin: 0;
  }

  /* ── RESPONSIVE ── */
  /* Tablet: 2-column wrap — hide horizontal line, show vertical connector */
  @media (max-width: 900px) {
    .ptl-track {
      flex-wrap: wrap;
      gap: 2rem 0;
    }
    .ptl-track::before { display: none; }
    .pstep { width: 33.33%; flex: none; }
  }
  /* Mobile: single column vertical timeline */
  @media (max-width: 580px) {
    .ptl-track { flex-direction: column; gap: 1.75rem; }
    .pstep {
      width: 100%; flex-direction: row;
      text-align: left; align-items: flex-start;
      gap: 1.1rem; padding: 0;
    }
    .pstep-icon-area {
      height: auto; padding-bottom: 0; flex-shrink: 0;
    }
    .pstep-num-wrap { margin-bottom: 0; flex-shrink: 0; }
    .pstep-body { flex: 1; }
  }
  .process-track { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0; position: relative; margin-top: 3rem; }
  .process-track::before { content: ''; position: absolute; top: 28px; left: 10%; right: 10%; height: 2px; background: linear-gradient(90deg, #7c3aed, #2563eb); z-index: 0; }
  .process-step { display: flex; flex-direction: column; align-items: center; text-align: center; position: relative; z-index: 1; padding: 0 0.5rem; }
  .step-num { width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, #7c3aed, #2563eb); display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 800; color: #fff; margin-bottom: 1rem; box-shadow: 0 0 20px rgba(124,58,237,0.5); border: 2px solid rgba(255,255,255,0.15); position: relative; }
  .step-num::after { content: ''; position: absolute; inset: -6px; border-radius: 50%; border: 1px solid rgba(124,58,237,0.3); }
  .process-step h4 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.4rem; }
  .process-step p { font-size: 0.78rem; color: var(--text-secondary); line-height: 1.5; }
  .step-icon { font-size: 1.5rem; margin-bottom: 0.5rem; }


  @media (max-width: 1024px) {
    .process-track { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .process-track::before { display: none; }
  }
  @media (max-width: 768px) {
    .process-track { grid-template-columns: 1fr; }
  }

</style>
