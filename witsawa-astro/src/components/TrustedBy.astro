---
const clientLogos = [
  "depa.png",
  "loreal.png",
  "nia.png",
  "samitivej.png",
  "sanofi.png",
  "tedfund.png",
  "thaioil.png",
  "ykt.png",
];
---

<section id="trusted-by">
  <div class="reveal" style="text-align:center;margin-bottom:0">
    <div class="solutions-badge">
      <span class="dot"></span>
      Trusted Technology Partner
    </div>
  </div>
  <div class="reveal reveal-delay-1">
    <h2 class="section-title" style="-webkit-text-fill-color:unset">
      <span style="color:#fff;-webkit-text-fill-color:#fff"
        >Powering Technology for</span
      ><br /><span class="grad">Leading Organizations</span>
    </h2>
  </div>
  <div class="reveal reveal-delay-1">
    <div class="tb-body">
      <p>Modern organizations require reliable technology partners.</p>
      <p>
        At Witsawa, we work closely with businesses to design and build scalable
        digital platforms that support growth, automation, and long-term
        innovation.
      </p>
    </div>
  </div>

  <!-- Scrolling logo marquee -->
  <div class="tb-strip-wrap reveal reveal-delay-2">
    <div class="tb-track">
      <!-- Set A -->
      {
        clientLogos.map((logo) => (
          <>
            <div class="tb-logo">
              <img
                src={`/clientLogos/${logo}`}
                alt="Client Logo"
                class="tb-logo-img"
              />
            </div>
            <div class="tb-sep" />
          </>
        ))
      }
      <!-- Set B — exact duplicate for seamless infinite loop -->
      {
        clientLogos.map((logo) => (
          <>
            <div class="tb-logo">
              <img
                src={`/clientLogos/${logo}`}
                alt="Client Logo"
                class="tb-logo-img"
              />
            </div>
            <div class="tb-sep" />
          </>
        ))
      }
    </div>
  </div>
</section>

<style is:global>
  /* ── TRUSTED BY v2: Marquee ── */
  #trusted-by {
    text-align: center;
    padding-top: 80px;
    padding-bottom: 80px;
    /* Dark overlay → image → gradient fallback */
    background:
      linear-gradient(rgba(0, 0, 0, 0.25), rgba(0, 0, 0, 0.25)),
      /* url("/images/cta-bg.jpg") center / cover no-repeat, */
      radial-gradient(
          ellipse at top left,
          #9f67f7 0%,
          #6b28d9 22%,
          #3b0d7a 50%,
          #0d0714 82%
        );
  }
  .tb-subtitle {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(168, 85, 247, 0.9);
    margin-bottom: 1rem;
  }
  .tb-subtitle::before {
    content: "";
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(168, 85, 247, 0.9);
    box-shadow: 0 0 8px rgba(168, 85, 247, 0.7);
  }
  .tb-title {
    font-size: clamp(1.5rem, 2.4vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 1.2rem;
  }
  .tb-body {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.85;
    max-width: 620px;
    margin: 0 auto 3rem;
  }
  .tb-body p {
    margin-bottom: 0.6rem;
  }
  .tb-strip-wrap {
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 10%,
      #000 90%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 10%,
      #000 90%,
      transparent 100%
    );
    padding: 0.75rem 0;
  }
  .tb-track {
    display: flex;
    gap: 3.5rem;
    animation: tb-marquee 32s linear infinite;
    width: max-content;
    align-items: center;
  }
  @keyframes tb-marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .tb-logo {
    display: flex;
    align-items: center;
    height: 40px;
    flex-shrink: 0;
    opacity: 0.7;
    filter: grayscale(1);
    transition:
      opacity 0.3s,
      filter 0.3s,
      transform 0.3s;
    cursor: default;
  }
  .tb-logo:hover {
    opacity: 1;
    filter: grayscale(0) brightness(1);
    transform: scale(1.05);
  }
  .tb-logo-img {
    max-height: 60px;
    width: auto;
    object-fit: contain;
  }
  .tb-sep {
    width: 1px;
    height: 22px;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
    margin: 0 0.25rem;
  }

  @media (max-width: 768px) {
    .tb-title {
      font-size: 1.4rem;
    }
    .tb-track {
      gap: 2rem;
    }
    .tb-logo {
      height: 34px;
    }
    .tb-logo-name {
      font-size: 0.82rem;
    }
  }
  @media (max-width: 580px) {
    .tb-track {
      gap: 2rem;
    }
  }
</style>
