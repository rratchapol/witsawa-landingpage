<style is:global>
  /* TECHNOLOGY INTEGRATIONS grid */
  .ti-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 1024px) and (min-width: 601px) {
    .ti-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .ti-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── TECH STACK: left-align heading to match site style ── */
  #tech .section-tag {
    justify-content: flex-start;
    text-align: left;
  }
  #tech .section-title {
    text-align: left;
    margin-left: 0;
    margin-right: 0;
  }
  #tech .section-sub {
    text-align: left;
    margin-left: 0;
    margin-right: 0;
  }

  /* TECH */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 1rem;
  }
  .tech-item {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 1.25rem 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s;
    cursor: default;
  }
  .tech-item:hover {
    border-color: rgba(168, 85, 247, 0.4);
    background: rgba(168, 85, 247, 0.07);
    transform: translateY(-4px);
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.15);
  }
  .tech-icon {
    font-size: 2rem;
    line-height: 1;
  }
  .tech-label {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-align: center;
  }

  /* SERVICE CARDS (From global.css) */
  .service-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 2rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
    cursor: default;
  }
  .service-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(168, 85, 247, 0.6),
      transparent
    );
    opacity: 0;
    transition: opacity 0.3s;
  }
  .service-card:hover {
    transform: translateY(-6px);
    border-color: rgba(168, 85, 247, 0.35);
    background: rgba(168, 85, 247, 0.07);
    box-shadow:
      0 0 40px rgba(168, 85, 247, 0.12),
      0 20px 40px rgba(0, 0, 0, 0.3);
  }
  .service-card:hover::before {
    opacity: 1;
  }
  .service-icon {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: linear-gradient(
      135deg,
      rgba(124, 58, 237, 0.25),
      rgba(37, 99, 235, 0.15)
    );
    border: 1px solid rgba(124, 58, 237, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin-bottom: 1.25rem;
    transition: box-shadow 0.3s;
  }
  .service-card:hover .service-icon {
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.4);
  }
  .service-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    letter-spacing: -0.02em;
  }
  .service-card p {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }
</style>
