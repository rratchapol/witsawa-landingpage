      <p>
        A modern technology consulting partner designing and building enterprise
        web apps, mobile platforms, and AI automation systems that drive real
        impact.
      </p>
      <div class="footer-social-icons">
        <!-- Facebook -->
        <a
          href="https://www.facebook.com/witsawa"
          target="_blank"
          rel="noopener"
          class="footer-social-btn"
          aria-label="Facebook"
