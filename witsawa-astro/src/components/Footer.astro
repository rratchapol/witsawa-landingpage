        <li><a href="/" onclick="scrollToId('hero');return false;">Home</a></li>
        <li>
          <a
            href="/#what-we-do"
            onclick="scrollToId('what-we-do');return false;">Services</a>
        </li>
        <li>
          <a href="/#solutions" onclick="scrollToId('solutions');return false;"
            >Solutions</a>
        </li>
        <li>
          <a
            href="/#case-studies"
            onclick="scrollToId('case-studies');return false;">Case Studies</a>
        </li>
        <li>
          <a href="/#cta" onclick="scrollToId('cta');return false;">Contact</a>
        </li>
      </ul>
    </div>
    <div class="footer-col">
      <h5>Contact</h5>
      <ul>
        <li class="footer-contact-item">
          <svg
            class="fc-icon"
